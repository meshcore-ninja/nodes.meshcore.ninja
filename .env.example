# Origin of the MeshCore Ninja API the directory queries.
VITE_API_BASE=https://api.meshcore.ninja

# Origin of the MeshCore Ninja catalog (networks.json). Defaults to meshcore.ninja.
VITE_CATALOG_ORIGIN=https://meshcore.ninja

# tangleveil multiplex WebSocket, used for the homepage live-advert feed.
VITE_TANGLEVEIL_WS=wss://tangleveil.meshcore.ninja/ws
